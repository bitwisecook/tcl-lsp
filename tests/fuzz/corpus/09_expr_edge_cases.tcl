# Expression edge cases
set a [expr {-1 * -1}]
set b [expr {2 ** 10}]
set c [expr {10 % 3}]
set d [expr {-10 % 3}]
set e [expr {1 == 1}]
set f [expr {1 != 2}]
set g [expr {1 < 2 ? "yes" : "no"}]
set h [expr {int(3.7)}]
set i [expr {double(42)}]
set j [expr {abs(-5)}]
set k [expr {max(3, 7)}]
set l [expr {min(3, 7)}]
set m [expr {wide(123)}]
