{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Tcl",
  "scopeName": "source.tcl",
  "fileTypes": ["tcl", "tk", "itcl", "tm"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#regexp-command" },
    { "include": "#command-substitution" },
    { "include": "#variable" },
    { "include": "#string-quoted" },
    { "include": "#string-braced" },
    { "include": "#keyword" },
    { "include": "#operator" },
    { "include": "#number" },
    { "include": "#escape" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.number-sign.tcl",
          "match": "(?:^|;)\\s*(#.*)$",
          "captures": {
            "1": { "name": "comment.line.number-sign.tcl" }
          }
        }
      ]
    },
    "regexp-command": {
      "comment": "regexp/regsub commands with embedded regex highlighting for the pattern argument",
      "patterns": [
        {
          "comment": "regexp/regsub with braced pattern: regexp {pattern} ...",
          "begin": "(?<=^|\\s|;|\\[)(regexp|regsub)\\s+((?:-[a-z]+\\s+)*(?:--\\s+)?)(\\{)",
          "end": "(\\})",
          "beginCaptures": {
            "1": { "name": "support.function.tcl" },
            "2": { "name": "meta.options.tcl", "patterns": [
              {
                "name": "keyword.operator.option.tcl",
                "match": "-(?:nocase|expanded|line|linestop|lineanchor|indices|all|inline|about|start)\\b"
              },
              {
                "name": "constant.numeric.tcl",
                "match": "\\b[0-9]+\\b"
              },
              {
                "name": "punctuation.separator.option-end.tcl",
                "match": "--"
              }
            ]},
            "3": { "name": "punctuation.definition.string.begin.regexp.tcl" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.string.end.regexp.tcl" }
          },
          "name": "string.regexp.tcl",
          "patterns": [
            { "include": "#regex-internals" }
          ]
        },
        {
          "comment": "regexp/regsub with quoted pattern: regexp \"pattern\" ...",
          "begin": "(?<=^|\\s|;|\\[)(regexp|regsub)\\s+((?:-[a-z]+\\s+)*(?:--\\s+)?)(\")",
          "end": "(\")",
          "beginCaptures": {
            "1": { "name": "support.function.tcl" },
            "2": { "name": "meta.options.tcl", "patterns": [
              {
                "name": "keyword.operator.option.tcl",
                "match": "-(?:nocase|expanded|line|linestop|lineanchor|indices|all|inline|about|start)\\b"
              },
              {
                "name": "constant.numeric.tcl",
                "match": "\\b[0-9]+\\b"
              },
              {
                "name": "punctuation.separator.option-end.tcl",
                "match": "--"
              }
            ]},
            "3": { "name": "punctuation.definition.string.begin.regexp.tcl" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.string.end.regexp.tcl" }
          },
          "name": "string.regexp.tcl",
          "patterns": [
            { "include": "#variable" },
            { "include": "#command-substitution" },
            { "include": "#regex-internals" }
          ]
        },
        {
          "comment": "regexp/regsub with bare pattern (no braces/quotes): regexp pattern ...",
          "match": "(?<=^|\\s|;|\\[)(regexp|regsub)\\s+((?:-[a-z]+\\s+)*(?:--\\s+)?)(\\S+)",
          "captures": {
            "1": { "name": "support.function.tcl" },
            "2": { "name": "meta.options.tcl", "patterns": [
              {
                "name": "keyword.operator.option.tcl",
                "match": "-(?:nocase|expanded|line|linestop|lineanchor|indices|all|inline|about|start)\\b"
              },
              {
                "name": "constant.numeric.tcl",
                "match": "\\b[0-9]+\\b"
              },
              {
                "name": "punctuation.separator.option-end.tcl",
                "match": "--"
              }
            ]},
            "3": { "name": "string.regexp.tcl" }
          }
        }
      ]
    },
    "regex-internals": {
      "comment": "Internal patterns for regex syntax highlighting",
      "patterns": [
        {
          "comment": "Character class: [abc], [^abc], [a-z]",
          "name": "constant.other.character-class.set.regexp.tcl",
          "begin": "(\\[)(\\^)?",
          "end": "(\\])",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.character-class.begin.regexp.tcl" },
            "2": { "name": "keyword.operator.negation.regexp.tcl" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.character-class.end.regexp.tcl" }
          },
          "patterns": [
            {
              "comment": "Range: a-z",
              "name": "constant.other.character-class.range.regexp.tcl",
              "match": "([^\\\\\\]])-(\\S)"
            },
            {
              "comment": "POSIX character class: [:alpha:]",
              "name": "constant.other.character-class.posix.regexp.tcl",
              "match": "\\[:[a-z]+:\\]"
            },
            { "include": "#regex-escape" }
          ]
        },
        {
          "comment": "Capturing group",
          "begin": "(\\()(\\?:|\\.\\*\\?)?",
          "end": "(\\))",
          "beginCaptures": {
            "1": { "name": "punctuation.definition.group.begin.regexp.tcl" },
            "2": { "name": "keyword.operator.group-modifier.regexp.tcl" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.definition.group.end.regexp.tcl" }
          },
          "name": "meta.group.regexp.tcl",
          "patterns": [
            { "include": "#regex-internals" }
          ]
        },
        {
          "comment": "Non-capturing group and lookaheads: (?:), (?=), (?!), (?<=), (?<!)",
          "match": "\\(\\?(?::|=|!|<=|<!|>)",
          "name": "keyword.operator.group-modifier.regexp.tcl"
        },
        {
          "comment": "Quantifiers: *, +, ?, {n}, {n,}, {n,m}",
          "match": "[*+?]|\\{\\d+(?:,\\d*)?\\}",
          "name": "keyword.operator.quantifier.regexp.tcl"
        },
        {
          "comment": "Alternation: |",
          "match": "\\|",
          "name": "keyword.operator.alternation.regexp.tcl"
        },
        {
          "comment": "Anchors: ^, $",
          "match": "\\^|\\$",
          "name": "keyword.operator.anchor.regexp.tcl"
        },
        {
          "comment": "Dot: matches any character",
          "match": "\\.",
          "name": "keyword.operator.wildcard.regexp.tcl"
        },
        {
          "comment": "Backreference: \\1 through \\9",
          "match": "\\\\[1-9]",
          "name": "keyword.operator.backreference.regexp.tcl"
        },
        { "include": "#regex-escape" },
        {
          "comment": "Nested braces (Tcl brace nesting within regex)",
          "begin": "\\{",
          "end": "\\}",
          "patterns": [
            { "include": "#regex-internals" }
          ]
        }
      ]
    },
    "regex-escape": {
      "comment": "Escape sequences within regex patterns",
      "patterns": [
        {
          "comment": "Character class shorthand: \\d, \\D, \\w, \\W, \\s, \\S, \\m, \\M, \\y, \\Y, \\A, \\Z",
          "match": "\\\\[dDwWsSmMyYAZ]",
          "name": "constant.character.escape.character-class.regexp.tcl"
        },
        {
          "comment": "Hex escape: \\xNN",
          "match": "\\\\x[0-9a-fA-F]{1,2}",
          "name": "constant.character.escape.hex.regexp.tcl"
        },
        {
          "comment": "Unicode escape: \\uNNNN",
          "match": "\\\\u[0-9a-fA-F]{1,4}",
          "name": "constant.character.escape.unicode.regexp.tcl"
        },
        {
          "comment": "Octal escape: \\0NN",
          "match": "\\\\0[0-7]{1,2}",
          "name": "constant.character.escape.octal.regexp.tcl"
        },
        {
          "comment": "General escape: backslash + special character",
          "match": "\\\\[.^$*+?()\\[\\]{}|\\\\/-]",
          "name": "constant.character.escape.regexp.tcl"
        },
        {
          "comment": "Named control escapes: \\n, \\t, \\r, \\a, \\b, \\f, \\v, \\e",
          "match": "\\\\[ntrabfve]",
          "name": "constant.character.escape.regexp.tcl"
        }
      ]
    },
    "command-substitution": {
      "patterns": [
        {
          "name": "meta.command-substitution.tcl",
          "begin": "\\[",
          "end": "\\]",
          "beginCaptures": {
            "0": { "name": "punctuation.section.bracket.begin.tcl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.bracket.end.tcl" }
          },
          "patterns": [
            { "include": "source.tcl" }
          ]
        }
      ]
    },
    "variable": {
      "patterns": [
        {
          "comment": "Braced variable: ${name with spaces}",
          "name": "variable.other.tcl",
          "match": "\\$\\{[^}]+\\}",
          "captures": {
            "0": { "name": "variable.other.braced.tcl" }
          }
        },
        {
          "comment": "Namespace-qualified variable with optional array: $ns::var(idx)",
          "name": "variable.other.tcl",
          "match": "\\$(?:[a-zA-Z_][a-zA-Z0-9_]*::)*[a-zA-Z_][a-zA-Z0-9_]*(?:\\([^)]*\\))?",
          "captures": {
            "0": { "name": "variable.other.tcl" }
          }
        }
      ]
    },
    "string-quoted": {
      "patterns": [
        {
          "name": "string.quoted.double.tcl",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.tcl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.tcl" }
          },
          "patterns": [
            { "include": "#variable" },
            { "include": "#command-substitution" },
            { "include": "#escape" }
          ]
        }
      ]
    },
    "string-braced": {
      "patterns": [
        {
          "comment": "Braced strings — no interpolation inside",
          "name": "string.other.braced.tcl",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.string.begin.tcl" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.string.end.tcl" }
          },
          "patterns": [
            { "include": "#string-braced" },
            { "include": "#escape" }
          ]
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "comment": "Control flow keywords",
          "name": "keyword.control.tcl",
          "match": "(?<=^|\\s|;|\\[)(?:if|else|elseif|for|foreach|while|switch|break|continue|return|catch|try|throw|yield|yieldto|tailcall)(?=\\s|$|;)"
        },
        {
          "comment": "Definition keywords",
          "name": "keyword.other.tcl",
          "match": "(?<=^|\\s|;|\\[)(?:proc|namespace|variable|global|upvar|uplevel|package|source|rename|interp|coroutine|apply)(?=\\s|$|;)"
        },
        {
          "comment": "Common built-in commands",
          "name": "support.function.tcl",
          "match": "(?<=^|\\s|;|\\[)(?:set|unset|puts|gets|read|open|close|expr|eval|info|array|dict|string|list|lappend|lassign|lindex|linsert|llength|lmap|lrange|lrepeat|lreplace|lreverse|lsearch|lset|lsort|join|split|format|scan|regexp|regsub|append|incr|after|file|glob|cd|pid|exec|socket|fconfigure|fileevent|flush|seek|tell|eof|fblocked|fcopy|chan|encoding|concat|subst|error|exit|time|update|vwait|parray|load|unload)(?=\\s|$|;)"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "comment": "Expr operators",
          "name": "keyword.operator.tcl",
          "match": "(?<=\\s)(?:eq|ne|in|ni|&&|\\|\\||!|==|!=|<=?|>=?)(?=\\s)"
        },
        {
          "comment": "Math operators inside expr",
          "name": "keyword.operator.arithmetic.tcl",
          "match": "(?<=\\s)[+\\-*/%](?=\\s)"
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "comment": "Hex number",
          "name": "constant.numeric.hex.tcl",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "comment": "Octal number",
          "name": "constant.numeric.octal.tcl",
          "match": "\\b0[oO][0-7]+\\b"
        },
        {
          "comment": "Binary number",
          "name": "constant.numeric.binary.tcl",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "comment": "Float or integer",
          "name": "constant.numeric.tcl",
          "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "escape": {
      "patterns": [
        {
          "comment": "Backslash escapes",
          "name": "constant.character.escape.tcl",
          "match": "\\\\(?:[abfnrtv\\\\\"\\{\\}\\[\\]\\$]|[0-7]{1,3}|x[0-9a-fA-F]{1,2}|u[0-9a-fA-F]{1,4}|\\n)"
        }
      ]
    }
  }
}
