# orchestrator.tcl -- Event orchestrator for iRule test framework
#
# Drives the event firing sequence based on virtual server profile
# configuration.  Uses event data generated from the Python registry
# (see _event_data.tcl) so there is a single source of truth.
#
# Usage:
#   source orchestrator.tcl
#   ::orch::configure -profiles {TCP CLIENTSSL HTTP} \
#                     -client_addr 10.0.0.1 -client_port 54321 \
#                     -local_addr 192.168.1.100 -local_port 443
#   ::orch::load_irule $irule_source
#   ::orch::add_pool web_pool {10.0.1.1:80 10.0.1.2:80}
#   ::orch::run_http_request -method GET -uri /api/health \
#       -host api.example.com -headers {x-forwarded-for 10.0.0.1}
#   ::orch::assert_pool_selected web_pool
#   ::orch::assert_decision lb pool_select web_pool
#
# For full control over event firing order:
#   ::orch::fire_sequence {CLIENT_ACCEPTED CLIENTSSL_HANDSHAKE HTTP_REQUEST}
#
# Copyright (c) 2024 tcl-lsp contributors.  MIT licence.

# Source generated event data (MASTER_ORDER, FLOW_CHAINS, etc.)
# Generated by: python -m core.irule_test.codegen_event_data
set _orch_event_file [file join [file dirname [info script]] _event_data.tcl]
if {![file exists $_orch_event_file]} {
    error "Missing generated file _event_data.tcl -- run: python -m core.irule_test.codegen_event_data"
}
source $_orch_event_file
unset _orch_event_file

namespace eval ::orch {

    # ── Configuration ─────────────────────────────────────────────────

    variable config
    array set config {
        profiles        {TCP HTTP}
        client_addr     10.0.0.1
        client_port     54321
        local_addr      192.168.1.100
        local_port      443
        tmos_version    16.1
        auto_lb         1
    }

    # Track connection state for multi-request scenarios
    variable _connection_active 0
    variable _init_done 0

    # Valid configure keys (anything else is a typo)
    variable _config_keys {profiles client_addr client_port local_addr local_port tmos_version auto_lb}

    proc configure {args} {
        variable config
        variable _config_keys
        foreach {opt val} $args {
            set key [string trimleft $opt -]
            if {$key ni $_config_keys} {
                error "unknown configure option \"-$key\" (valid: [join $_config_keys {, }])"
            }
            set config($key) $val
        }
    }

    proc load_irule {source} {
        ::itest::load_irule $source
    }

    proc add_pool {name members args} {
        eval [list ::state::lb::add_pool $name $members] $args
    }

    proc configure_static {varname value} {
        set ::static::$varname $value
    }

    proc add_datagroup {name type records} {
        ::state::datagroup::add $name $type $records
    }

    # ── Flow chain selection ──────────────────────────────────────────

    proc _select_chain {} {
        variable config
        variable FLOW_CHAINS

        set profiles $config(profiles)
        set upper [list]
        foreach p $profiles {
            lappend upper [string toupper $p]
        }

        set best_chain ""
        set best_score -1
        set best_extra 999

        foreach chain_name [array names FLOW_CHAINS] {
            set chain $FLOW_CHAINS($chain_name)
            # Extract profiles from chain
            set chain_profiles [list]
            foreach {k v} $chain {
                if {$k eq "profiles"} { set chain_profiles $v }
            }

            # Score: how many of the chain's profiles match ours
            set overlap 0
            set extra 0
            foreach cp $chain_profiles {
                if {[lsearch -exact $upper $cp] >= 0} {
                    incr overlap
                } else {
                    incr extra
                }
            }

            if {$overlap > $best_score || ($overlap == $best_score && $extra < $best_extra)} {
                set best_chain $chain_name
                set best_score $overlap
                set best_extra $extra
            }
        }

        return $best_chain
    }

    proc _chain_events {chain_name} {
        variable FLOW_CHAINS
        set chain $FLOW_CHAINS($chain_name)
        set steps [list]
        foreach {k v} $chain {
            if {$k eq "steps"} { set steps $v }
        }
        set events [list]
        foreach step $steps {
            lappend events [lindex $step 0]
        }
        return $events
    }

    # ── Event gate check ──────────────────────────────────────────────
    #
    # Check if an event should fire given the current profile set.

    proc _event_gated {event_name} {
        variable MASTER_ORDER
        variable config

        set profiles $config(profiles)
        set upper [list]
        foreach p $profiles {
            lappend upper [string toupper $p]
        }

        foreach entry $MASTER_ORDER {
            set ename [lindex $entry 0]
            set gates [lindex $entry 1]
            if {$ename eq $event_name} {
                # Empty gates = always allowed
                if {[llength $gates] == 0} { return 0 }
                # Check if any gate profile is in our set
                foreach gp $gates {
                    if {[lsearch -exact $upper $gp] >= 0} {
                        return 0
                    }
                }
                return 1  ;# gated out
            }
        }
        return 1  ;# unknown event
    }

    # ── State setup helpers ───────────────────────────────────────────

    proc _setup_connection {} {
        variable config
        ::state::connection::configure \
            -client_addr $config(client_addr) \
            -client_port $config(client_port) \
            -local_addr  $config(local_addr) \
            -local_port  $config(local_port) \
            -vip_addr    $config(local_addr) \
            -vip_port    $config(local_port)
    }

    proc _setup_tls {args} {
        foreach {k v} $args {
            set key [string trimleft $k -]
            set ::state::tls::client::$key $v
        }
    }

    proc _setup_http_request {args} {
        eval [list ::state::http::request::configure] $args
    }

    proc _setup_http_response {args} {
        eval [list ::state::http::response::configure] $args
    }

    # ── Core event firing ─────────────────────────────────────────────

    proc fire {event_name args} {
        # Set up state for the event if provided
        foreach {k v} $args {
            switch -exact -- [string trimleft $k -] {
                http_request  { _setup_http_request {*}$v }
                http_response { _setup_http_response {*}$v }
                tls           { _setup_tls {*}$v }
            }
        }

        # Fire the event
        return [::itest::fire_event $event_name]
    }

    # Fire a specific sequence of events (full user control)
    proc fire_sequence {events} {
        set results [list]
        foreach event $events {
            if {![_event_gated $event]} {
                lappend results $event [::itest::fire_event $event]
            }
        }
        return $results
    }

    # ── High-level test scenarios ─────────────────────────────────────

    # Run a complete connection lifecycle with one HTTP request/response
    proc run_http_request {args} {
        variable config
        variable _connection_active
        variable _init_done

        # Parse args
        set method "GET"
        set uri "/"
        set host ""
        set headers [list]
        set sni ""
        set resp_status 200
        set resp_headers [list]
        set resp_payload ""

        foreach {k v} $args {
            switch -exact -- [string trimleft $k -] {
                method       { set method $v }
                uri          { set uri $v }
                host         { set host $v }
                headers      { set headers $v }
                sni          { set sni $v }
                response_status  { set resp_status $v }
                response_headers { set resp_headers $v }
                response_payload { set resp_payload $v }
            }
        }

        # In auto TMM mode, fakeCMP hash selects TMM from connection tuple.
        variable _tmm_select_mode
        if {[_tmm_enabled] && $_tmm_select_mode eq "auto"} {
            _fakecmp_auto_select
        }

        set chain [_select_chain]
        if {$chain eq ""} {
            error "no flow chain matches profiles: $config(profiles)"
        }
        set chain_events [_chain_events $chain]

        # Reset per-request state
        if {$_connection_active} {
            ::state::reset_request_state
            ::itest::reset_decisions
        } else {
            ::state::reset_connection_state
            ::itest::reset_decisions
            set _connection_active 1
        }

        # Set up connection state
        _setup_connection

        # Set up TLS state
        if {$sni ne ""} {
            set ::state::tls::client::sni $sni
        } elseif {$host ne ""} {
            set ::state::tls::client::sni $host
        }

        # Set up HTTP request state
        set ::state::http::request::method $method
        set ::state::http::request::uri $uri
        # Derive path/query
        set qpos [string first "?" $uri]
        if {$qpos >= 0} {
            set ::state::http::request::path [string range $uri 0 [expr {$qpos - 1}]]
            set ::state::http::request::query [string range $uri [expr {$qpos + 1}] end]
        } else {
            set ::state::http::request::path $uri
            set ::state::http::request::query ""
        }
        set ::state::http::request::host $host
        foreach {hname hval} $headers {
            ::state::http::request::header set $hname $hval
        }
        if {$host ne ""} {
            ::state::http::request::header set "host" $host
        }

        # Set up HTTP response state (for response events)
        set ::state::http::response::status $resp_status
        foreach {hname hval} $resp_headers {
            ::state::http::response::header set $hname $hval
        }
        set ::state::http::response::payload $resp_payload

        # Fire events in chain order, only those the iRule handles
        set results [list]
        set registered [::itest::registered_events]
        set skip_rest 0

        foreach event $chain_events {
            if {$skip_rest} break

            # Skip RULE_INIT if already done for this connection set
            if {$event eq "RULE_INIT" && $_init_done} continue

            # Only fire events the iRule has handlers for, plus
            # structural events that advance the connection state
            set has_handler [expr {[lsearch -exact $registered $event] >= 0}]

            # Mark TLS handshake as complete
            if {$event eq "CLIENTSSL_HANDSHAKE"} {
                set ::state::tls::client::handshake_done 1
            }
            if {$event eq "SERVERSSL_HANDSHAKE"} {
                set ::state::tls::server::handshake_done 1
            }

            if {$event eq "RULE_INIT"} {
                set _init_done 1
            }

            # Auto-LB: set up server-side state after LB_SELECTED
            if {$event eq "LB_SELECTED" && $config(auto_lb)} {
                # If no pool selected yet by the iRule during HTTP_REQUEST,
                # that's fine -- the iRule may not select a pool
            }
            if {$event eq "SERVER_CONNECTED"} {
                if {$::state::lb::node_addr ne ""} {
                    set ::state::connection::server_addr $::state::lb::node_addr
                    set ::state::connection::server_port $::state::lb::node_port
                    set ::state::connection::remote_addr $::state::lb::node_addr
                    set ::state::connection::remote_port $::state::lb::node_port
                }
            }

            if {$has_handler} {
                set result [::itest::fire_event $event]
                lappend results $event $result

                # Check if connection was dropped/rejected
                if {$::state::connection::state eq "closing"} {
                    set skip_rest 1
                }
                # Check if HTTP response was committed (redirect/respond)
                if {$::state::http::response_committed && $event eq "HTTP_REQUEST"} {
                    # Short-circuit: no server-side events
                    set skip_rest 1
                }
            }
        }

        # In multi-TMM mode, save statics back to the TMM slot
        if {[_tmm_enabled]} {
            _tmm_save_statics
        }

        return $results
    }

    # Run an additional HTTP request on the same connection (keep-alive).
    # Only fires per-request events (HTTP_REQUEST onward), preserving
    # connection and TLS state from the initial run_http_request call.
    proc run_next_request {args} {
        variable _connection_active
        variable config
        variable _init_done

        if {!$_connection_active} {
            error "no active connection -- call run_http_request first"
        }
        # Reset per-request state but keep connection state
        ::state::reset_request_state
        ::itest::reset_decisions

        # Parse args the same way run_http_request does
        set method "GET"; set uri "/"; set host ""; set sni ""
        set headers [list]; set resp_status 200
        set resp_headers [list]; set resp_payload ""
        foreach {opt val} $args {
            switch -exact -- $opt {
                -method          { set method $val }
                -uri             { set uri $val }
                -host            { set host $val }
                -sni             { set sni $val }
                -headers         { set headers $val }
                -response_status { set resp_status $val }
                -response_headers { set resp_headers $val }
                -response_payload { set resp_payload $val }
            }
        }

        # Set up HTTP state (but NOT connection/TLS state)
        set ::state::http::request::method $method
        set ::state::http::request::uri $uri
        set qpos [string first "?" $uri]
        if {$qpos >= 0} {
            set ::state::http::request::path [string range $uri 0 [expr {$qpos - 1}]]
            set ::state::http::request::query [string range $uri [expr {$qpos + 1}] end]
        } else {
            set ::state::http::request::path $uri
            set ::state::http::request::query ""
        }
        set ::state::http::request::host $host
        foreach {hname hval} $headers {
            ::state::http::request::header set $hname $hval
        }
        if {$host ne ""} {
            ::state::http::request::header set "host" $host
        }
        set ::state::http::response::status $resp_status
        foreach {hname hval} $resp_headers {
            ::state::http::response::header set $hname $hval
        }
        set ::state::http::response::payload $resp_payload

        # Fire only per-request events (skip init, connection, TLS phases)
        set _per_request_phases {http_request lb l4_server http_request_server http_response dns_request dns_response}
        set chain [_select_chain]
        if {$chain eq ""} {
            error "no flow chain matches profiles: $config(profiles)"
        }

        variable FLOW_CHAINS
        set chain_data $FLOW_CHAINS($chain)
        set steps [list]
        foreach {k v} $chain_data {
            if {$k eq "steps"} { set steps $v }
        }

        set results [list]
        set registered [::itest::registered_events]
        set skip_rest 0

        foreach step $steps {
            if {$skip_rest} break
            set event [lindex $step 0]
            set phase [lindex $step 1]

            # Skip connection-level phases on keep-alive
            if {[lsearch -exact $_per_request_phases $phase] < 0} continue

            set has_handler [expr {[lsearch -exact $registered $event] >= 0}]
            if {$has_handler} {
                set result [::itest::fire_event $event]
                lappend results $event $result
                if {$::state::connection::state eq "closing"} {
                    set skip_rest 1
                }
                if {$::state::http::response_committed && $event eq "HTTP_REQUEST"} {
                    set skip_rest 1
                }
            }
        }

        # In multi-TMM mode, save statics back to the TMM slot
        if {[_tmm_enabled]} {
            _tmm_save_statics
        }

        return $results
    }

    # Close the current connection
    proc close_connection {} {
        variable _connection_active
        variable _init_done

        if {$_connection_active} {
            # Fire CLIENT_CLOSED
            ::itest::fire_event CLIENT_CLOSED
        }
        set _connection_active 0
        set _init_done 0
        ::state::reset_connection_state
    }

    # ── Assertion engine ─────────────────────────────────────────────
    #
    # Two APIs:
    #   1. Classic: assert_pool_selected, assert_decision, etc.
    #   2. Fluent:  assert that pool_selected equals "api_pool"
    #
    # Both share the same pass/fail counters and failure list.

    variable _assert_count 0
    variable _assert_failures [list]

    # ── Internal: record pass/fail ────────────────────────────────

    proc _assert_pass {} {
        variable _assert_count
        incr _assert_count
        return 1
    }

    proc _assert_fail {msg} {
        variable _assert_count
        variable _assert_failures
        incr _assert_count
        lappend _assert_failures $msg
        # Output in a format parseable by editors (file:line prefix when available)
        puts stderr "    FAIL: $msg"
        return 0
    }

    # ── Classic assertion helpers ─────────────────────────────────

    proc assert {condition message} {
        if {![uplevel 1 [list expr $condition]]} {
            return [_assert_fail $message]
        }
        return [_assert_pass]
    }

    proc assert_equal {actual expected {message ""}} {
        if {$actual ne $expected} {
            set detail "assert_equal failed"
            if {$message ne ""} { append detail ": $message" }
            append detail "\n      expected: \"$expected\""
            append detail "\n        actual: \"$actual\""
            # Show character-level diff hint for short strings
            if {[string length $actual] < 200 && [string length $expected] < 200} {
                set la [string length $actual]
                set le [string length $expected]
                set minlen [expr {$la < $le ? $la : $le}]
                for {set i 0} {$i < $minlen} {incr i} {
                    if {[string index $actual $i] ne [string index $expected $i]} {
                        append detail "\n      first diff at index $i"
                        break
                    }
                }
                if {$la != $le} {
                    append detail "\n      lengths differ: expected $le, got $la"
                }
            }
            return [_assert_fail $detail]
        }
        return [_assert_pass]
    }

    proc assert_not_equal {actual unexpected {message ""}} {
        if {$actual eq $unexpected} {
            set detail "assert_not_equal failed"
            if {$message ne ""} { append detail ": $message" }
            append detail "\n      got: \"$actual\" (expected something different)"
            return [_assert_fail $detail]
        }
        return [_assert_pass]
    }

    proc assert_pool_selected {expected_pool} {
        set actual $::state::lb::pool
        if {$actual ne $expected_pool} {
            return [_assert_fail "expected pool \"$expected_pool\" but got \"$actual\""]
        }
        return [_assert_pass]
    }

    proc assert_decision {category action {value ""}} {
        set decisions [::itest::get_decisions $category]
        foreach d $decisions {
            set d_action [lindex $d 1]
            set d_args [lindex $d 2]
            if {$d_action eq $action} {
                if {$value eq "" || [lindex $d_args 0] eq $value} {
                    return [_assert_pass]
                }
            }
        }
        set msg "expected decision: $category $action"
        if {$value ne ""} { append msg " $value" }
        append msg " (got: $decisions)"
        return [_assert_fail $msg]
    }

    proc assert_no_decision {category action} {
        set decisions [::itest::get_decisions $category]
        foreach d $decisions {
            if {[lindex $d 1] eq $action} {
                return [_assert_fail "expected no decision $category $action but found one"]
            }
        }
        return [_assert_pass]
    }

    proc assert_log_contains {pattern} {
        set logs [::state::log_capture::get]
        foreach entry $logs {
            set msg [lindex $entry 2]
            if {[string match $pattern $msg]} {
                return [_assert_pass]
            }
        }
        return [_assert_fail "no log message matching \"$pattern\""]
    }

    proc assert_http_header {name expected} {
        set actual [::state::http::request::header get $name]
        if {$actual ne $expected} {
            return [_assert_fail "expected HTTP header \"$name\" = \"$expected\" but got \"$actual\""]
        }
        return [_assert_pass]
    }

    proc assert_http_uri {expected} {
        set actual $::state::http::request::uri
        if {$actual ne $expected} {
            return [_assert_fail "expected HTTP URI \"$expected\" but got \"$actual\""]
        }
        return [_assert_pass]
    }

    proc assert_connection_state {expected} {
        set actual $::state::connection::state
        if {$actual ne $expected} {
            return [_assert_fail "expected connection state \"$expected\" but got \"$actual\""]
        }
        return [_assert_pass]
    }

    # ── Fluent assertion DSL ──────────────────────────────────────
    #
    # Usage:
    #   assert that pool_selected equals "api_pool"
    #   assert that http_uri equals "/v1/health"
    #   assert that http_header "Host" equals "api.example.com"
    #   assert that decision lb pool_select was_called
    #   assert that decision lb pool_select was_called_with "api_pool"
    #   assert that decision connection reject was_not_called
    #   assert that log matches "*rejected*"
    #   assert that log does_not_match "*error*"
    #   assert that event HTTP_RESPONSE was_fired
    #   assert that event HTTP_RESPONSE was_not_fired
    #   assert that tls_sni equals "api.example.com"
    #   assert that connection_state equals "established"
    #   assert that var "static::debug" equals "1"

    proc assert_that {args} {
        set subject [lindex $args 0]

        switch -exact -- $subject {
            decision {
                return [_fluent_decision [lrange $args 1 end]]
            }
            log {
                return [_fluent_log [lrange $args 1 end]]
            }
            event {
                return [_fluent_event [lrange $args 1 end]]
            }
            http_header {
                return [_fluent_http_header [lrange $args 1 end]]
            }
            response_header {
                return [_fluent_response_header [lrange $args 1 end]]
            }
            var {
                return [_fluent_var [lrange $args 1 end]]
            }
            tmm_var {
                return [_fluent_tmm_var [lrange $args 1 end]]
            }
            default {
                # State property: pool_selected, http_uri, etc.
                return [_fluent_state $subject [lrange $args 1 end]]
            }
        }
    }

    # ── Fluent: state properties ──────────────────────────────────
    #
    # Maps readable names to state variable values.

    proc _fluent_resolve_state {prop_name} {
        switch -exact -- $prop_name {
            pool_selected      { return $::state::lb::pool }
            node_selected      { return $::state::lb::node_addr }
            snat               { return $::state::lb::snat_addr }
            http_method        { return $::state::http::request::method }
            http_uri           { return $::state::http::request::uri }
            http_path          { return $::state::http::request::path }
            http_query         { return $::state::http::request::query }
            http_host          { return $::state::http::request::host }
            http_version       { return $::state::http::request::version }
            http_status        { return $::state::http::response::status }
            response_committed { return $::state::http::response_committed }
            client_addr        { return $::state::connection::client_addr }
            client_port        { return $::state::connection::client_port }
            server_addr        { return $::state::connection::server_addr }
            server_port        { return $::state::connection::server_port }
            local_addr         { return $::state::connection::local_addr }
            local_port         { return $::state::connection::local_port }
            connection_state   { return $::state::connection::state }
            tls_sni            { return $::state::tls::client::sni }
            tls_cipher         { return $::state::tls::client::cipher_name }
            ip_protocol        { return $::state::connection::protocol }
            default {
                error "unknown state property \"$prop_name\" in assert that"
            }
        }
    }

    proc _fluent_state {prop_name rest} {
        set actual [_fluent_resolve_state $prop_name]
        return [_fluent_compare $prop_name $actual $rest]
    }

    # ── Fluent: comparison verbs ──────────────────────────────────

    proc _fluent_compare {label actual rest} {
        set verb [lindex $rest 0]
        set expected [lindex $rest 1]

        switch -exact -- $verb {
            equals - eq - is {
                if {$actual ne $expected} {
                    return [_assert_fail "$label: expected \"$expected\" but got \"$actual\""]
                }
                return [_assert_pass]
            }
            not_equals - ne - is_not {
                if {$actual eq $expected} {
                    return [_assert_fail "$label: expected not \"$expected\" but got it"]
                }
                return [_assert_pass]
            }
            matches {
                if {![string match $expected $actual]} {
                    return [_assert_fail "$label: \"$actual\" does not match pattern \"$expected\""]
                }
                return [_assert_pass]
            }
            does_not_match {
                if {[string match $expected $actual]} {
                    return [_assert_fail "$label: \"$actual\" unexpectedly matches pattern \"$expected\""]
                }
                return [_assert_pass]
            }
            contains {
                if {[string first $expected $actual] < 0} {
                    return [_assert_fail "$label: \"$actual\" does not contain \"$expected\""]
                }
                return [_assert_pass]
            }
            does_not_contain {
                if {[string first $expected $actual] >= 0} {
                    return [_assert_fail "$label: \"$actual\" unexpectedly contains \"$expected\""]
                }
                return [_assert_pass]
            }
            starts_with {
                set plen [string length $expected]
                if {[string range $actual 0 [expr {$plen - 1}]] ne $expected} {
                    return [_assert_fail "$label: \"$actual\" does not start with \"$expected\""]
                }
                return [_assert_pass]
            }
            ends_with {
                set slen [string length $expected]
                set start [expr {[string length $actual] - $slen}]
                if {$start < 0 || [string range $actual $start end] ne $expected} {
                    return [_assert_fail "$label: \"$actual\" does not end with \"$expected\""]
                }
                return [_assert_pass]
            }
            default {
                error "unknown assertion verb \"$verb\" in assert that $label"
            }
        }
    }

    # ── Fluent: decisions ─────────────────────────────────────────

    proc _fluent_decision {rest} {
        set category [lindex $rest 0]
        set action [lindex $rest 1]
        set verb [lindex $rest 2]
        set value [lindex $rest 3]

        set decisions [::itest::get_decisions $category]
        set found 0
        set found_value ""

        foreach d $decisions {
            if {[lindex $d 1] eq $action} {
                set found 1
                set found_value [lindex $d 2]
                break
            }
        }

        switch -exact -- $verb {
            was_called {
                if {!$found} {
                    return [_assert_fail "decision $category $action: was not called"]
                }
                return [_assert_pass]
            }
            was_not_called {
                if {$found} {
                    return [_assert_fail "decision $category $action: was called but expected not"]
                }
                return [_assert_pass]
            }
            was_called_with {
                if {!$found} {
                    return [_assert_fail "decision $category $action: was not called (expected with \"$value\")"]
                }
                if {[lindex $found_value 0] ne $value} {
                    return [_assert_fail "decision $category $action: called with \"[lindex $found_value 0]\" not \"$value\""]
                }
                return [_assert_pass]
            }
            default {
                error "unknown decision verb \"$verb\" in assert that decision"
            }
        }
    }

    # ── Fluent: log ───────────────────────────────────────────────

    proc _fluent_log {rest} {
        set verb [lindex $rest 0]
        set pattern [lindex $rest 1]

        set logs [::state::log_capture::get]
        set found 0
        foreach entry $logs {
            set msg [lindex $entry 2]
            if {[string match $pattern $msg]} {
                set found 1
                break
            }
        }

        switch -exact -- $verb {
            matches - contains_match {
                if {!$found} {
                    return [_assert_fail "log: no message matching \"$pattern\""]
                }
                return [_assert_pass]
            }
            does_not_match {
                if {$found} {
                    return [_assert_fail "log: found unexpected message matching \"$pattern\""]
                }
                return [_assert_pass]
            }
            default {
                error "unknown log verb \"$verb\" in assert that log"
            }
        }
    }

    # ── Fluent: events ────────────────────────────────────────────

    proc _fluent_event {rest} {
        set event_name [lindex $rest 0]
        set verb [lindex $rest 1]

        # Check actually fired events (not just registered handlers)
        set fired_events [::itest::get_fired_events]
        set was_fired [expr {[lsearch -exact $fired_events $event_name] >= 0}]

        # Also check registered (for is_registered verb)
        set registered [::itest::registered_events]
        set is_registered [expr {[lsearch -exact $registered $event_name] >= 0}]

        switch -exact -- $verb {
            was_fired {
                if {!$was_fired} {
                    return [_assert_fail "event $event_name: was not fired"]
                }
                return [_assert_pass]
            }
            is_registered {
                if {!$is_registered} {
                    return [_assert_fail "event $event_name: is not registered"]
                }
                return [_assert_pass]
            }
            was_not_fired {
                if {$was_fired} {
                    return [_assert_fail "event $event_name: was fired but expected not"]
                }
                return [_assert_pass]
            }
            is_not_registered {
                if {$is_registered} {
                    return [_assert_fail "event $event_name: is registered but expected not"]
                }
                return [_assert_pass]
            }
            default {
                error "unknown event verb \"$verb\" in assert that event"
            }
        }
    }

    # ── Fluent: HTTP headers ──────────────────────────────────────

    proc _fluent_http_header {rest} {
        set header_name [lindex $rest 0]
        set actual [::state::http::request::header get $header_name]
        return [_fluent_compare "http_header($header_name)" $actual [lrange $rest 1 end]]
    }

    proc _fluent_response_header {rest} {
        set header_name [lindex $rest 0]
        set actual [::state::http::response::header get $header_name]
        return [_fluent_compare "response_header($header_name)" $actual [lrange $rest 1 end]]
    }

    # ── Fluent: variables ─────────────────────────────────────────

    proc _fluent_var {rest} {
        set var_name [lindex $rest 0]
        # Check static:: namespace, then state::vars arrays
        if {[string match "static::*" $var_name]} {
            if {[::info exists ::$var_name]} {
                set actual [set ::$var_name]
            } else {
                set actual ""
            }
        } elseif {[::info exists ::state::vars::statics($var_name)]} {
            set actual $::state::vars::statics($var_name)
        } elseif {[::info exists ::state::vars::connection_vars($var_name)]} {
            set actual $::state::vars::connection_vars($var_name)
        } else {
            set actual ""
        }
        return [_fluent_compare "var($var_name)" $actual [lrange $rest 1 end]]
    }

    # ── Fluent: TMM-specific variables ──────────────────────────────
    #
    # Usage: assert_that tmm_var <tmm_id> <varname> <verb> <expected>
    # Reads a static variable from a specific TMM slot.

    proc _fluent_tmm_var {rest} {
        set tmm_id [lindex $rest 0]
        set var_name [lindex $rest 1]
        # Strip "static::" prefix if present for the lookup
        set lookup_name $var_name
        if {[string match "static::*" $var_name]} {
            set lookup_name [string range $var_name 8 end]
        }
        set actual [tmm_get_static $tmm_id $lookup_name]
        return [_fluent_compare "tmm${tmm_id}::${var_name}" $actual [lrange $rest 2 end]]
    }

    # Print test summary (assertion-level, for imperative-style scripts)
    proc summary {} {
        variable _assert_count
        variable _assert_failures
        set passed [expr {$_assert_count - [llength $_assert_failures]}]
        set failed [llength $_assert_failures]

        puts ""
        if {$failed > 0} {
            puts "Assertions failing: \[$failed\]"
            puts ""
            foreach msg $_assert_failures {
                puts "FAILED: $msg"
            }
            puts ""
        }

        puts "Total\t$_assert_count\tPassed\t$passed\tSkipped\t0\tFailed\t$failed"

        if {$failed == 0} {
            puts "All tests passed"
        }

        return [expr {$failed == 0}]
    }

    # Reset test state
    proc reset {} {
        variable _assert_count 0
        variable _assert_failures [list]
        variable _connection_active 0
        variable _init_done 0
        ::state::reset_all
        ::itest::reset_decisions
        ::itest::clear_irule

        # Reset multi-TMM state
        variable _tmm_count
        variable _tmm_current
        variable _tmm_select_mode
        set _tmm_select_mode "manual"
        if {$_tmm_count > 1} {
            set _tmm_current 0
            _tmm_init_slots
        }
    }

    # ══════════════════════════════════════════════════════════════════
    # Test runner -- tcltest-style named test cases
    # ══════════════════════════════════════════════════════════════════
    #
    # Usage:
    #   ::orch::test "routing-1.0" "routes API traffic to api_pool" -body {
    #       ::orch::run_http_request -host api.example.com
    #       ::orch::assert_that pool_selected equals api_pool
    #   }
    #
    #   ::orch::test "routing-1.1" "rejects unknown hosts" \
    #       -setup { ::orch::add_pool web {10.0.0.1:80} } \
    #       -body {
    #           ::orch::run_http_request -host evil.com
    #           ::orch::assert_that decision connection reject was_called
    #       }
    #
    #   ::orch::test "ssl-2.0" "requires clientssl" \
    #       -constraints {ssl} \
    #       -body { ... }
    #
    #   ::orch::done  ;# prints summary and sets exit code
    #
    # Each test gets automatic reset + init, so tests are isolated.
    # The -setup block runs after init; -cleanup runs after the body.

    variable _test_results [list]   ;# {name desc status ?message?}
    variable _test_count 0
    variable _test_passed 0
    variable _test_failed 0
    variable _test_skipped 0
    variable _test_constraints [list]
    variable _test_irule ""
    variable _test_profiles {TCP HTTP}
    variable _test_setup_shared ""
    variable _test_verbose 1

    proc configure_tests {args} {
        # Configure test runner defaults.
        #   -profiles {TCP HTTP}
        #   -irule { when HTTP_REQUEST { ... } }
        #   -setup { ::orch::add_pool ... }
        #   -verbose 0|1|2
        #   -constraints {ssl dns}
        foreach {key val} $args {
            set k [string trimleft $key -]
            switch -exact -- $k {
                profiles       { variable _test_profiles; set _test_profiles $val }
                irule          { variable _test_irule; set _test_irule $val }
                setup          { variable _test_setup_shared; set _test_setup_shared $val }
                verbose        { variable _test_verbose; set _test_verbose $val }
                constraints    { variable _test_constraints; set _test_constraints $val }
                tmm_count      {
                    variable _tmm_count
                    set _tmm_count $val
                    if {$_tmm_count > 1} {
                        _tmm_init_slots
                    }
                }
                tmm_select     {
                    variable _tmm_select_mode
                    set _tmm_select_mode $val
                }
                default {
                    error "unknown configure_tests option \"-$k\" (valid: -profiles, -irule, -setup, -verbose, -constraints, -tmm_count, -tmm_select)"
                }
            }
        }
    }

    proc test {name desc args} {
        variable _test_results
        variable _test_count
        variable _test_passed
        variable _test_failed
        variable _test_skipped
        variable _test_irule
        variable _test_profiles
        variable _test_setup_shared
        variable _test_verbose
        variable _test_constraints

        # Parse options: -body, -setup, -cleanup, -constraints
        # Note: tcltest's -match/-result pattern is intentionally not supported.
        # Use assertions inside -body instead (assert_equal, assert_that, etc.)
        set body ""
        set setup ""
        set cleanup ""
        set constraints [list]

        set i 0
        while {$i < [llength $args]} {
            set opt [lindex $args $i]
            incr i
            switch -exact -- $opt {
                -body        { set body [lindex $args $i]; incr i }
                -setup       { set setup [lindex $args $i]; incr i }
                -cleanup     { set cleanup [lindex $args $i]; incr i }
                -constraints { set constraints [lindex $args $i]; incr i }
                default      { error "unknown option \"$opt\" in ::orch::test (supported: -body, -setup, -cleanup, -constraints)" }
            }
        }

        if {$body eq ""} {
            error "::orch::test \"$name\" requires -body"
        }

        incr _test_count

        # Check constraints
        foreach c $constraints {
            if {$c ni $_test_constraints} {
                incr _test_skipped
                if {$_test_verbose >= 2} {
                    puts "---- $name SKIPPED ($c)"
                }
                lappend _test_results [list $name $desc "SKIP" "constraint: $c"]
                return
            }
        }

        # Isolate: reset + init
        reset
        ::orch::init
        ::orch::configure -profiles $_test_profiles

        # Shared setup (iRule, pools, etc.)
        if {$_test_irule ne ""} {
            ::orch::load_irule $_test_irule
        }
        if {$_test_setup_shared ne ""} {
            uplevel 1 $_test_setup_shared
        }
        # Per-test setup
        if {$setup ne ""} {
            uplevel 1 $setup
        }

        # Reset assertion counters for this test
        variable _assert_count 0
        variable _assert_failures [list]

        # Run body
        set err ""
        set code [catch {uplevel 1 $body} result opts]

        # Cleanup (always runs)
        if {$cleanup ne ""} {
            catch {uplevel 1 $cleanup}
        }

        # Evaluate result
        if {$code == 1} {
            # Tcl error
            incr _test_failed
            set errmsg $result
            if {$_test_verbose >= 1} {
                puts "==== $name $desc FAILED"
                puts "---- error: $errmsg"
            }
            lappend _test_results [list $name $desc "FAIL" "error: $errmsg"]
        } elseif {[llength $_assert_failures] > 0} {
            # Assertion failures
            incr _test_failed
            set fails [join $_assert_failures "; "]
            if {$_test_verbose >= 1} {
                puts "==== $name $desc FAILED"
                foreach f $_assert_failures {
                    puts "---- $f"
                }
            }
            lappend _test_results [list $name $desc "FAIL" $fails]
        } else {
            # Passed
            incr _test_passed
            if {$_test_verbose >= 2} {
                puts "++++ $name PASSED"
            }
            lappend _test_results [list $name $desc "PASS" ""]
        }
    }

    proc done {} {
        variable _test_results
        variable _test_count
        variable _test_passed
        variable _test_failed
        variable _test_skipped

        # Print summary in tcltest-compatible format
        puts ""
        if {$_test_failed > 0} {
            puts "Tests failing: \[$_test_failed\]"
            puts ""
            foreach r $_test_results {
                if {[lindex $r 2] eq "FAIL"} {
                    set tname [lindex $r 0]
                    set tdesc [lindex $r 1]
                    set tmsg  [lindex $r 3]
                    puts "FAILED: $tname"
                    puts "    $tdesc"
                    # Print each line of the failure message indented
                    foreach line [split $tmsg "\n"] {
                        puts "    $line"
                    }
                    puts ""
                }
            }
        }

        puts "Total\t$_test_count\tPassed\t$_test_passed\tSkipped\t$_test_skipped\tFailed\t$_test_failed"

        if {$_test_count == 0} {
            puts "No tests found."
        } elseif {$_test_failed == 0 && $_test_skipped == 0} {
            puts "All tests passed"
        } elseif {$_test_failed == 0} {
            puts "All tests passed ($_test_skipped skipped)"
        }

        # Return exit code (0 = all pass, 1 = failures)
        return [expr {$_test_failed > 0}]
    }

    # Convenience: run done and exit with appropriate code
    proc run_and_exit {} {
        set failed [done]
        exit $failed
    }

    # ══════════════════════════════════════════════════════════════════
    # Multi-TMM simulation
    # ══════════════════════════════════════════════════════════════════
    #
    # On real BIG-IP, each TMM core has its own copy of static::
    # variables (RULE_INIT fires independently per TMM).  The table
    # command is CMP-shared across all TMMs.  This mode lets you find
    # bugs like "static variable updated on one TMM but not others".
    #
    # Usage:
    #   ::orch::configure_tests -tmm_count 4
    #
    #   ::orch::test "cmp-1.0" "static vars are per-TMM" -body {
    #       ::orch::tmm_select 0
    #       ::orch::run_http_request -host api.example.com
    #       # TMM 0 incremented static::counter
    #
    #       ::orch::tmm_select 1
    #       ::orch::run_http_request -host api.example.com
    #       # TMM 1 has its own static::counter
    #
    #       ::orch::assert_that tmm_var 0 "static::counter" equals "1"
    #       ::orch::assert_that tmm_var 1 "static::counter" equals "1"
    #   }
    #
    # What is per-TMM (isolated):
    #   - static:: variables
    #   - RULE_INIT execution state
    #   - connection state (each connection lives on one TMM)
    #
    # What is shared (CMP):
    #   - table command (session tables)
    #   - data groups (config, read-only)
    #
    # When tmm_count is 0 or 1 (default), the framework operates in
    # classic single-TMM mode with no overhead.

    variable _tmm_count      0       ;# 0 = single-TMM mode (default)
    variable _tmm_current    0       ;# currently active TMM index
    variable _tmm_statics    [list]  ;# list of dicts: tmm_id -> {varname value ...}
    variable _tmm_init_done  [list]  ;# list of booleans: has RULE_INIT fired?

    proc _tmm_enabled {} {
        variable _tmm_count
        return [expr {$_tmm_count > 1}]
    }

    proc _tmm_init_slots {} {
        variable _tmm_count
        variable _tmm_statics
        variable _tmm_init_done

        set _tmm_statics [list]
        set _tmm_init_done [list]
        for {set i 0} {$i < $_tmm_count} {incr i} {
            lappend _tmm_statics [dict create]
            lappend _tmm_init_done 0
        }
    }

    # Save current ::static:: namespace into the current TMM slot
    proc _tmm_save_statics {} {
        variable _tmm_count
        variable _tmm_current
        variable _tmm_statics

        if {$_tmm_count < 2} return

        set snapshot [dict create]
        foreach var [::tmm::_orig_info vars ::static::*] {
            set name [::tmm::_orig_namespace tail $var]
            if {[array exists $var]} {
                # Array variable: store as dict
                dict set snapshot $name [list array [array get $var]]
            } else {
                dict set snapshot $name [list scalar [set $var]]
            }
        }
        lset _tmm_statics $_tmm_current $snapshot
    }

    # Restore ::static:: namespace from a TMM slot
    proc _tmm_restore_statics {tmm_id} {
        variable _tmm_statics

        # Clear current statics
        foreach var [::tmm::_orig_info vars ::static::*] {
            catch { unset $var }
        }

        set snapshot [lindex $_tmm_statics $tmm_id]
        dict for {name val} $snapshot {
            set type [lindex $val 0]
            set data [lindex $val 1]
            if {$type eq "array"} {
                array set ::static::$name $data
            } else {
                set ::static::$name $data
            }
        }
    }

    # Select which TMM handles the next connection.
    # Saves the current TMM's statics and restores the target TMM's.
    proc tmm_select {tmm_id} {
        variable _tmm_count
        variable _tmm_current

        if {$_tmm_count < 2} {
            error "tmm_select requires -tmm_count >= 2 in configure_tests"
        }
        if {$tmm_id < 0 || $tmm_id >= $_tmm_count} {
            error "TMM $tmm_id out of range (0..[expr {$_tmm_count - 1}])"
        }

        # Save current TMM state
        _tmm_save_statics

        # Switch
        set _tmm_current $tmm_id

        # Restore target TMM state
        _tmm_restore_statics $tmm_id

        # If RULE_INIT hasn't fired on this TMM yet, fire it
        variable _tmm_init_done
        if {![lindex $_tmm_init_done $tmm_id]} {
            lset _tmm_init_done $tmm_id 1
            catch {::itest::fire_event RULE_INIT}
            # Save the statics after RULE_INIT
            _tmm_save_statics
        }

        # Mark RULE_INIT as done for the orchestrator (so run_http_request
        # doesn't re-fire it -- tmm_select handles per-TMM RULE_INIT)
        variable _init_done
        set _init_done 1

        # Reset connection state (new connection on this TMM)
        variable _connection_active
        set _connection_active 0
        ::state::reset_connection_state
        ::itest::reset_decisions
    }

    # Read a static variable from a specific TMM without switching to it.
    proc tmm_get_static {tmm_id varname} {
        variable _tmm_count
        variable _tmm_current
        variable _tmm_statics

        if {$_tmm_count < 2} {
            # Single-TMM mode: just read from ::static::
            if {[::tmm::_orig_info exists ::static::$varname]} {
                return [set ::static::$varname]
            }
            return ""
        }

        # If it's the current TMM, read live
        if {$tmm_id == $_tmm_current} {
            if {[::tmm::_orig_info exists ::static::$varname]} {
                return [set ::static::$varname]
            }
            return ""
        }

        # Otherwise read from snapshot
        set snapshot [lindex $_tmm_statics $tmm_id]
        if {[dict exists $snapshot $varname]} {
            set val [dict get $snapshot $varname]
            set type [lindex $val 0]
            set data [lindex $val 1]
            if {$type eq "scalar"} {
                return $data
            } else {
                return $data  ;# return array as list for inspection
            }
        }
        return ""
    }

    # List all TMM IDs
    proc tmm_ids {} {
        variable _tmm_count
        if {$_tmm_count < 2} { return {0} }
        set ids [list]
        for {set i 0} {$i < $_tmm_count} {incr i} {
            lappend ids $i
        }
        return $ids
    }

    # Get the current TMM ID
    proc tmm_current {} {
        variable _tmm_current
        return $_tmm_current
    }

    # Assert on a specific TMM's static variable
    # Usage: ::orch::assert_that tmm_var <tmm_id> <varname> <verb> <expected>
    # (Registered as a fluent subject in assert_that)

    # ── fakeCMP: simulated CMP hash for TMM selection ─────────────
    #
    # Real BIG-IP TMOS uses a hardware CMP hash on (src_ip, src_port,
    # dst_ip, dst_port) to select which TMM handles a connection.
    # This is a *simulated* hash -- not the real algorithm -- hence
    # "fakeCMP".  It's deterministic and distributes well enough for
    # testing, but don't compare its output to real BIG-IP behavior.
    #
    # Usage:
    #   ::orch::configure_tests -tmm_count 4 -tmm_select auto
    #
    # With -tmm_select auto, run_http_request automatically selects the
    # TMM via fakeCMP hash.  Override client_addr / client_port in
    # ::orch::configure to simulate different source tuples.
    #
    # The -tmm_select option can be:
    #   "manual"  - (default) user calls tmm_select explicitly
    #   "auto"    - fakeCMP hash selects TMM from connection 4-tuple

    variable _tmm_select_mode "manual"

    # fakeCMP hash: deterministic TMM from connection 4-tuple.
    # NOT the real BIG-IP CMP algorithm -- a test-only simulation.
    proc _fakecmp_hash {src_addr src_port dst_addr dst_port} {
        variable _tmm_count
        # Simple hash: combine all 4 tuple elements into a
        # deterministic integer, then mod by TMM count.
        set hash 0
        foreach octet [split $src_addr .] {
            set hash [expr {($hash * 31 + $octet) & 0x7FFFFFFF}]
        }
        set hash [expr {($hash * 31 + $src_port) & 0x7FFFFFFF}]
        foreach octet [split $dst_addr .] {
            set hash [expr {($hash * 31 + $octet) & 0x7FFFFFFF}]
        }
        set hash [expr {($hash * 31 + $dst_port) & 0x7FFFFFFF}]
        return [expr {$hash % $_tmm_count}]
    }

    # Auto-select TMM from current connection config.
    # Called by run_http_request when _tmm_select_mode is "auto".
    proc _fakecmp_auto_select {} {
        variable config
        set tmm_id [_fakecmp_hash \
            $config(client_addr) $config(client_port) \
            $config(local_addr) $config(local_port)]
        tmm_select $tmm_id
    }

    # ── fakeCMP tools: query and plan TMM distribution ────────────

    # fakecmp_which_tmm -- look up which TMM a connection tuple maps to.
    #
    # Usage:
    #   set tmm [::orch::fakecmp_which_tmm 10.0.0.1 12345 192.168.1.100 443]
    #   set tmm [::orch::fakecmp_which_tmm]  ;# uses current config
    #
    # Returns: integer TMM ID (0 .. tmm_count-1)
    proc fakecmp_which_tmm {args} {
        variable config
        variable _tmm_count
        if {$_tmm_count < 2} {
            return 0
        }
        if {[llength $args] == 4} {
            return [_fakecmp_hash \
                [lindex $args 0] [lindex $args 1] \
                [lindex $args 2] [lindex $args 3]]
        } elseif {[llength $args] == 0} {
            return [_fakecmp_hash \
                $config(client_addr) $config(client_port) \
                $config(local_addr) $config(local_port)]
        } else {
            error "fakecmp_which_tmm: expected 0 or 4 args (src_addr src_port dst_addr dst_port)"
        }
    }

    # fakecmp_suggest_sources -- find client_addr/port combos that
    # land on each TMM.  Returns a dict: tmm_id → {addr port addr port ...}
    #
    # Usage:
    #   set plan [::orch::fakecmp_suggest_sources]
    #   set plan [::orch::fakecmp_suggest_sources -count 3]
    #   set plan [::orch::fakecmp_suggest_sources -dst_addr 10.1.1.100 -dst_port 80]
    #
    # Each TMM gets at least -count (default 1) source tuples.
    # The search scans 10.0.0.1-10.0.0.254 with ports 10001+.
    proc fakecmp_suggest_sources {args} {
        variable _tmm_count
        if {$_tmm_count < 2} {
            return [dict create 0 {10.0.0.1 10001}]
        }

        # Parse options
        variable config
        set count 1
        set dst_addr $config(local_addr)
        set dst_port $config(local_port)
        foreach {k v} $args {
            switch -exact -- [string trimleft $k -] {
                count    { set count $v }
                dst_addr { set dst_addr $v }
                dst_port { set dst_port $v }
            }
        }

        # Collect sources for each TMM
        set result [dict create]
        for {set t 0} {$t < $_tmm_count} {incr t} {
            dict set result $t [list]
        }
        set need [expr {$_tmm_count * $count}]
        set found 0

        for {set octet 1} {$octet <= 254 && $found < $need} {incr octet} {
            for {set port 10001} {$port <= 10254 && $found < $need} {incr port} {
                set addr "10.0.0.$octet"
                set tmm [_fakecmp_hash $addr $port $dst_addr $dst_port]
                set current [dict get $result $tmm]
                if {[expr {[llength $current] / 2}] < $count} {
                    lappend current $addr $port
                    dict set result $tmm $current
                    incr found
                }
            }
        }

        return $result
    }

    # fakecmp_plan -- pretty-print a distribution plan for multi-TMM tests.
    # Returns human-readable text showing which sources hit which TMMs.
    #
    # Usage:
    #   puts [::orch::fakecmp_plan]
    #   puts [::orch::fakecmp_plan -count 2]
    proc fakecmp_plan {args} {
        variable _tmm_count
        set plan [fakecmp_suggest_sources {*}$args]
        set lines [list]
        lappend lines "fakeCMP distribution plan ($_tmm_count TMMs):"
        for {set t 0} {$t < $_tmm_count} {incr t} {
            set sources [dict get $plan $t]
            set pairs [list]
            foreach {addr port} $sources {
                lappend pairs "$addr:$port"
            }
            lappend lines "  TMM $t: [join $pairs {, }]"
        }
        return [join $lines "\n"]
    }
}

# ── Convenience: init everything ──────────────────────────────────

proc ::orch::init {args} {
    # Parse optional tmos_version
    set tmos "16.1"
    foreach {k v} $args {
        if {[string trimleft $k -] eq "tmos_version"} { set tmos $v }
    }

    # Initialise TMM shim
    ::tmm::init -tmos_version $tmos

    # Install expression operators
    ::tmm::expr_ops::install

    # Register command mocks
    ::itest::cmd::register_all

    # Install unknown handler
    ::itest::install_unknown

    return
}
