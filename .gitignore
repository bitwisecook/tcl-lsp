# Override global gitignore rules that conflict with project structure
!/lsp/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.hypothesis/
.coverage
.coverage.*
htmlcov/
.eggs/
*.egg-info/
build/
dist/
.venv/
venv/
env/
pip-wheel-metadata/

# Node / TypeScript
node_modules/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Project tool outputs
editors/vscode/out/
editors/vscode/.vscode-test/
.vscode-test/
lsp/_build_info.py
explorer/static/build_info.json
uv.lock
editors/vscode/uv.lock
editors/vscode/package-lock.json
.claude/settings.local.json
.claude/worktrees/
docs/screenshots/.shell-ready
docs/screenshots/.ai-done
docs/screenshots/.ai-started
docs/screenshots/.ai-success
.vscode/

# JetBrains plugin build artifacts
editors/jetbrains/build/
editors/jetbrains/.gradle/
editors/jetbrains/src/main/resources/tcl-lsp-server.pyz
editors/jetbrains/src/main/resources/compilerExplorer.html


# KCS help database (generated by scripts/build_kcs_db.py)
core/help/kcs_help.db

# Local build artefacts
tmp/
