{# Main iRule test script template.
   Variables:
     test_name   — base name (basename minus extension)
     basename    — original file name
     source      — raw iRule source (string)
     profiles    — list[str] of profile names
     setup_lines — list[str] of setup body lines (already indented)
     test_blocks — list[str] of rendered test case blocks
     multi_tmm   — dict|None with multi-TMM config, or None to skip
#}
# test_{{ test_name }}.tcl -- Generated tests for {{ basename }}
#
# Generated by: tcl_ai.py generate-test
# Customize the test scenarios below to match expected behavior.
#
# Run with: tclsh test_{{ test_name }}.tcl

set script_dir [file dirname [info script]]

# Source the test framework
source [file join $script_dir compat84.tcl]
source [file join $script_dir state_layers.tcl]
source [file join $script_dir tmm_shim.tcl]
source [file join $script_dir expr_ops.tcl]
source [file join $script_dir command_mocks.tcl]
if {[file exists [file join $script_dir _mock_stubs.tcl]]} {
    source [file join $script_dir _mock_stubs.tcl]
}
source [file join $script_dir itest_core.tcl]
source [file join $script_dir orchestrator.tcl]

# ── Configure test defaults ──

::orch::configure_tests \
    -profiles {{ "{" }}{{ profiles | join(" ") }}{{ "}" }} \
    -irule {
{{ source | indent(8, first=true) }}
    }
{% if setup_lines %}

::orch::configure_tests -setup {
{% for line in setup_lines %}
{{ line }}
{% endfor %}
}
{% endif %}

{% for block in test_blocks %}
{{ block }}

{% endfor %}
{% if multi_tmm %}
{% include "multi_tmm.tcl.j2" %}

{% endif %}
# ── Summary ──

exit [::orch::done]
